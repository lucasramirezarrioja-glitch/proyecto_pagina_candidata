# Supabase — copia este archivo a .env.local y rellena los valores
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sbp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Solo para uso en servidor (nunca expongas en el cliente)
# Obtén esta clave en https://supabase.com/dashboard/project/<your-project-id>/settings/api
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Configuración pública de la app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
